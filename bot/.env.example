# Telegram Bot Token（從 @BotFather 取得）
TELEGRAM_TOKEN=你的_BOT_TOKEN

# Supabase 連線資訊（從 Supabase Dashboard > Project Settings > API 複製）
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=your-anon-public-key

# 儀表板網址（Vercel 部署後填入）
DASHBOARD_URL=https://your-app.vercel.app

# 允許記帳的 Telegram user_id（逗號分隔，傳訊息給 @userinfobot 取得）
# 留空則所有人都能用（開發測試用）
ALLOWED_USER_IDS=123456789,987654321
